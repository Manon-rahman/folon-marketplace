# Copy to .env and fill in real values before running docker compose

# ── Express backend ───────────────────────────────────────────────────────────

# JWT secrets — generate with: openssl rand -base64 32
JWT_SECRET=change-me-at-least-32-characters-long
JWT_REFRESH_SECRET=change-me-at-least-32-characters-long-too

# Stripe — from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
FRONTEND_URL=http://localhost:3000

# ── folon-marketplace (Next.js) ───────────────────────────────────────────────

# Session secret — generate with: openssl rand -base64 32
SESSION_SECRET=change-me-at-least-32-characters-long!!

# Admin login for /admin
ADMIN_EMAIL=admin@folon.app
ADMIN_PASSWORD=change-me-strong-password

# App identity (optional — defaults shown)
APP_ID=folon
APP_NAME=Folon Marketplace
NEXT_PUBLIC_APP_NAME=Folon Marketplace
NEXT_PUBLIC_PRIMARY_COLOR=#4CA771
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# bKash PGW (leave blank for sandbox defaults)
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_SANDBOX=true

# Vercel Blob (image uploads)
BLOB_READ_WRITE_TOKEN=
