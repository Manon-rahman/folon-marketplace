# App identity
APP_ID=folon
APP_NAME=Folon Marketplace
NEXT_PUBLIC_APP_NAME=Folon Marketplace
NEXT_PUBLIC_PRIMARY_COLOR=#4CA771

# Database (Neon recommended — copy both URLs from Neon dashboard)
DATABASE_URL=postgresql://...
DIRECT_URL=postgresql://...

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password

# Session (generate: openssl rand -base64 32)
SESSION_SECRET=replace-with-32-char-secret-minimum

# Phase 2 only — JWT handshake with host app
HANDSHAKE_SECRET=

# Phase 2 only — Krishop API
KRISHOP_API_URL=
KRISHOP_API_KEY=

# Image uploads (Vercel Blob)
# Get this from: Vercel dashboard → Storage → Blob → Connect → copy BLOB_READ_WRITE_TOKEN
BLOB_READ_WRITE_TOKEN=

# bKash PGW sandbox
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_SANDBOX=true
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# SMS (SSL Wireless)
SMS_API_KEY=
SMS_SENDER_ID=
